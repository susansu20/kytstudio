# ── Google Calendar (required for live availability + bookings) ─────────────
# Follow the "Google Calendar setup" walkthrough in README.md.
# Without these three, the app runs in DEMO MODE: fake availability, no real
# calendar events — useful for previewing the design.

# The service account's email, e.g. kyt-bookings@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# The service account's private key from the downloaded JSON file (the "private_key"
# field). Keep the quotes and the \n characters exactly as they appear in the JSON:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# The ID of the booking calendar (Google Calendar → calendar Settings → "Calendar ID").
# For a main calendar this is just the account's email address — the studio
# syncs with the contact@kytstudio.net Google account's calendar.
GOOGLE_CALENDAR_ID=contact@kytstudio.net

# ── Upstash Redis (required in production: locks, settings, rate limiting) ──
# Create a free database at https://console.upstash.com → copy the REST URL + token.
# Without these, an in-memory fallback is used (fine for local dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Resend (transactional email) ─────────────────────────────────────────────
# Create an API key at https://resend.com and verify the kytstudio.net domain.
# Without a key, emails are skipped and logged to the server console.
RESEND_API_KEY=

# The From address for customer emails. Must be on a domain verified in Resend.
EMAIL_FROM="The Kyt Studio <contact@kytstudio.net>"

# Where owner notifications go (new bookings, after-hours enquiries) — the
# studio also receives a bcc copy of every customer confirmation here.
OWNER_NOTIFICATION_EMAIL=contact@kytstudio.net

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password for /admin/settings. Pick something long and random.
ADMIN_PASSWORD=

# ── Site ──────────────────────────────────────────────────────────────────────
# Canonical origin. Use https://book.kytstudio.net while on the subdomain,
# switch to https://kytstudio.net if/when the page replaces /studio-rental.
NEXT_PUBLIC_SITE_URL=https://book.kytstudio.net
